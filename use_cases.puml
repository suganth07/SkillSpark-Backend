@startuml SkillSpark_Use_Cases

' UML Use Case Diagram for SkillSpark Backend System
' Following UML 2.5 Standards
' Optimized for Landscape/PPT Presentation

!define LAYOUT_LEFT_RIGHT left to right direction

LAYOUT_LEFT_RIGHT

skinparam shadowing false
skinparam backgroundColor transparent
skinparam packageStyle rectangle

actor User as U

rectangle "SkillSpark Backend System" {
  
  rectangle "Authentication" {
    usecase "Register Account" as UC1
    usecase "Login" as UC2
    usecase "Check Username\nAvailability" as UC3
  }
  
  rectangle "Learning Management" {
    usecase "Generate Roadmap" as UC4
    usecase "Save Roadmap" as UC5
    usecase "View My Roadmaps" as UC6
    usecase "Update Roadmap" as UC7
    usecase "Delete Roadmap" as UC8
    usecase "Track Progress" as UC9
    usecase "Mark Point\nComplete" as UC10
  }
  
  rectangle "Video Content" {
    usecase "Generate Video\nPlaylist" as UC11
    usecase "Regenerate Videos" as UC12
    usecase "View Videos\nby Level" as UC13
    usecase "Paginate Video\nResults" as UC14
  }
  
  rectangle "User Preferences" {
    usecase "Manage Settings" as UC15
    usecase "Set Learning\nPreferences" as UC16
    usecase "Configure Roadmap\nDepth" as UC17
    usecase "Set Video Length\nPreference" as UC18
  }
  
  rectangle "Data Management" {
    usecase "Clear All Data" as UC19
    usecase "Delete Account" as UC20
    usecase "Export Progress" as UC21
  }
  
  rectangle "Topic Management" {
    usecase "Create Learning\nTopic" as UC22
    usecase "View Topics" as UC23
    usecase "Search Topics" as UC24
  }
  
}

' User Associations (positioned for landscape)
U --> UC1
U --> UC2
U --> UC3
U --> UC4
U --> UC5
U --> UC6
U --> UC7
U --> UC8
U --> UC9
U --> UC10
U --> UC11
U --> UC12
U --> UC13
U --> UC14
U --> UC15
U --> UC16
U --> UC17
U --> UC18
U --> UC19
U --> UC20
U --> UC21
U --> UC22
U --> UC23
U --> UC24

' Include Dependencies (UML Standard)
UC4 ..> UC22 : <<include>>
UC5 ..> UC22 : <<include>>
UC11 ..> UC6 : <<include>>
UC12 ..> UC13 : <<include>>

' Extend Dependencies (UML Standard)
UC16 <.. UC4 : <<extend>>
UC17 <.. UC11 : <<extend>>
UC18 <.. UC11 : <<extend>>

' Notes positioned for landscape layout
note bottom of UC4 : Uses AI (Gemini) to generate\npersonalized learning roadmaps
note bottom of UC11 : Searches YouTube for videos\nusing AI-generated titles
note bottom of UC9 : Tracks completion status\nwith timestamps

@enduml
